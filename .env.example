DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dota_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dota_analyzer

# Local demo/dev data can run without real API keys.
USE_DEMO_DATA=false
USE_DEV_SEED=false

# Real data source keys are optional for local startup.
# OpenDota may work partly without a key, but a key can improve rate limits.
OPENDOTA_API_KEY=

# STRATZ requires an API key; missing key disables STRATZ sync without breaking the app.
STRATZ_API_KEY=

# PandaScore requires an API key; missing key disables PandaScore sync without breaking the app.
PANDASCORE_API_KEY=

# Optional multi-bookmaker odds aggregator. Missing key disables automatic odds sync.
SPORTSGAMEODDS_API_KEY=

# Real sync safety defaults.
DATA_SYNC_DRY_RUN_DEFAULT=true
DATA_SYNC_REQUIRE_TIER1=true

# Prospective forecast refresh. Fifteen minutes keeps the two-hour final window reliable.
# The scheduler enforces a minimum interval of 300 seconds.
FORECAST_REFRESH_INTERVAL_SECONDS=900
FORECAST_REFRESH_STALE_MINUTES=45

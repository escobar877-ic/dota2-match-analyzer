# Local credentials and environment overrides
.env
.env.*
!.env.example

# macOS and editor state
.DS_Store
**/.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Python
.venv/
venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime logs and local databases
*.log
*.pid
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db

# Generated ML models, reports, caches, and rollback artifacts
ml/artifacts/*
!ml/artifacts/.gitkeep
*.pkl
*.joblib

# Validated local backups stay on the operator machine
backups/*
!backups/.gitkeep
*.dump
*.tar.gz

# Local-only workspace material unrelated to the analyzer repository
.hermes.md
dialog-spy-bot/
portfolio-hermes/
